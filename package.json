{
  "name": "pulsate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.development -- \"prisma generate --schema ./prisma/postgresql/schema.prisma && next dev --turbopack\"",
    "dev-prod-db": "dotenv -e .env.production -- \"prisma generate --schema ./prisma/cockroachdb/schema.prisma && next dev --turbo\"",
    "build-local": "prisma generate --schema ./prisma/postgresql/schema.prisma && next build",
    "build": "prisma generate --schema ./prisma/cockroachdb/schema.prisma && next build",
    "start-local": "dotenv -e .env.development -- next start",
    "start-prod": "dotenv -e .env.production -- next start",
    "lint": "next lint",
    "db-push-local": "dotenv -e .env.development -- npx prisma db push --schema ./prisma/postgresql/schema.prisma",
    "db-push-prod": "dotenv -e .env.production -- npx prisma db push --schema ./prisma/cockroachdb/schema.prisma",
    "db-generate-local": "dotenv -e .env.development -- npx prisma generate --schema ./prisma/postgresql/schema.prisma",
    "db-generate-prod": "dotenv -e .env.production -- npx prisma generate --schema ./prisma/cockroachdb/schema.prisma",
    "studio-local": "dotenv -e .env.development -- npx prisma studio --schema ./prisma/postgresql/schema.prisma",
    "studio-prod": "dotenv -e .env.production -- npx prisma studio --schema ./prisma/cockroachdb/schema.prisma"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.6",
    "@prisma/client": "^6.19.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@stripe/stripe-js": "^1.54.1",
    "@tanstack/react-query": "^5.25.0",
    "@tanstack/react-table": "^8.10.7",
    "@types/node": "^24.1.0",
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.8",
    "@vercel/analytics": "^1.3.1",
    "@vercel/postgres": "^0.10.0",
    "autoprefixer": "10.4.14",
    "class-variance-authority": "^0.6.1",
    "clsx": "^1.2.1",
    "cmdk": "^0.2.0",
    "date-fns": "^2.30.0",
    "eslint": "^10.1.0",
    "eslint-config-next": "^0.2.4",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.0.7",
    "next": "^15.5.9",
    "next-auth": "^4.22.1",
    "next-themes": "^0.2.1",
    "nodemailer": "^7.0.13",
    "postcss": "^8.4.33",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.3",
    "qrcode.react": "^3.1.0",
    "radix-ui": "latest",
    "react": "^18.3.1",
    "react-day-picker": "^9.10.0",
    "react-dom": "^18.3.1",
    "react-icons": "^4.9.0",
    "react-wrap-balancer": "^1.0.0",
    "recharts": "^2.13.0-alpha.4",
    "stripe": "^12.9.0",
    "tailwind-merge": "^1.14.0",
    "tailwindcss": "3.3.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^6.12.0"
  },
  "overrides": {
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.8"
  }
}
